# =============================================================================
# CLM Backend — Environment Template
# Copy this file to .env and fill in every value marked <REPLACE>.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI  (required — all LLM features depend on this)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=<REPLACE_WITH_YOUR_OPENAI_API_KEY>

# LLM model used across all services (chunking, compliance, review, draft,
# agent workflow, knowledge graph, comparison chat, cypher chat).
OPENAI_CHAT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Neo4j  (required for Knowledge Graph / Cypher Chat features)
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j+s://<REPLACE>.databases.neo4j.io
NEO4J_USER=<REPLACE_WITH_NEO4J_USERNAME>
NEO4J_PASSWORD=<REPLACE_WITH_NEO4J_PASSWORD>
NEO4J_DATABASE=<REPLACE_WITH_NEO4J_DATABASE_NAME>
# Set to false to disable richer schema hints for Cypher generation
NEO4J_ENHANCED_SCHEMA=true

# -----------------------------------------------------------------------------
# Database
# Defaults to SQLite at data/sql_app.db (relative to backend dir).
# Switch to postgresql+psycopg2://user:pass@host/dbname for production.
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/sql_app.db

# -----------------------------------------------------------------------------
# Storage paths  (relative to the backend working directory)
# -----------------------------------------------------------------------------
UPLOAD_DIR=data/uploads
DOCX_PREVIEW_CACHE_DIR=data/preview_cache
DOCUMENT_DRIVE_DIR=data/document_drive

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.  Use * to allow all (dev only).
# Example:  CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*
